EMAIL_PROVIDER=brevo
EMAIL_API_KEY=your-api-key-here
EMAIL_SECRET_KEY=your-mailjet-secret-key-here
EMAIL_FROM=noreply@yourdomain.com
# Public site key used by the browser and frontend build
TURNSTILE_SITE_KEY=your-turnstile-site-key
# Optional local-only override for development and test runs on localhost
TURNSTILE_SITE_KEY_OVERRIDE=your-turnstile-test-site-key
# Private secret used only by the backend to validate Turnstile tokens
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Optional local-only secret matching TURNSTILE_SITE_KEY_OVERRIDE
TURNSTILE_SECRET_KEY_OVERRIDE=your-turnstile-test-secret-key
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
EMAIL_SEND_COOLDOWN_SECONDS=60
EMAIL_SEND_MAX_ATTEMPTS=5
ALLOWED_ORIGINS=http://localhost:5173
DOWNLOAD_BASE_URL=http://localhost:8000
MAX_UPLOAD_SIZE_MB=20
FILE_EXPIRY_HOURS=24
